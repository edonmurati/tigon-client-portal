generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum Role {
  ADMIN
  CLIENT
}

enum OwnerTag {
  GENT
  EDON
  BEIDE
}

enum ClientStage {
  COLD
  WARM
  ACTIVE
  PRO_BONO
  PAUSED
  ENDED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum ProjectType {
  CLIENT_PROJECT
  PRODUCT
  INTERNAL
}

enum ProjectHealth {
  GREEN
  AMBER
  RED
}

enum TaskKind {
  TODO
  INITIATIVE
  RESEARCH
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  PARKED
  CANCELLED
}

enum TaskPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ImpulseType {
  FEEDBACK
  CHANGE_REQUEST
  QUESTION
  IDEA
}

enum ImpulseStatus {
  NEW
  SEEN
  IN_PROGRESS
  ACCEPTED
  REJECTED
  DONE
}

enum ImpulsePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum JournalKind {
  HANDOFF
  CHANGELOG
  NOTE
}

enum EntryCategory {
  SPEC
  PLAN
  MEETING_NOTE
  IDEA
  INSIGHT
  RESEARCH
  OTHER
}

enum DecisionStatus {
  ACTIVE
  SUPERSEDED
  REVERSED
}

enum LeadStatus {
  NEW
  QUALIFIED
  OUTREACH_SENT
  FOLLOWUP_1
  FOLLOWUP_2
  REPLIED
  IN_CONVERSATION
  MEETING_BOOKED
  CONVERTED
  REJECTED
  UNRESPONSIVE
  PARKED
}

enum LeadTier {
  TIER_1
  TIER_2
  TIER_3
}

enum LeadSource {
  APIFY_GMAPS
  REFERRAL
  LINKEDIN
  INBOUND
  MANUAL
  OTHER
}

enum ActivityKind {
  OUTREACH_SENT
  OUTREACH_REPLY
  CALL
  MEETING
  WHATSAPP
  EMAIL
  IN_PERSON
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  DEPLOYED
  MILESTONE_REACHED
  IMPULSE_ACCEPTED
  IMPULSE_RESOLVED
  NOTE
}

enum ActivityChannel {
  EMAIL
  PHONE
  WHATSAPP
  SMS
  MEETING_ONLINE
  MEETING_OFFLINE
  LINKEDIN
  OTHER
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum InvoiceKind {
  ONE_OFF
  RETAINER
  MILESTONE
  DEPOSIT
}

enum PaymentMethod {
  BANK_TRANSFER
  SEPA_DD
  STRIPE
  PAYPAL
  CASH
  OTHER
}

enum ExpenseCategory {
  AI_TOOLING
  INFRASTRUCTURE
  HOSTING
  SAAS
  DOMAIN
  LEGAL
  OFFICE
  OTHER
}

enum ExpenseFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum PipelineStage {
  QUALIFIED
  IN_CONVERSATION
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  STALLED
}

enum CredentialType {
  LOGIN
  API_KEY
  ENV_VARIABLE
  SSH_KEY
  DATABASE
  TOKEN
  CERTIFICATE
  OTHER
}

enum DocumentCategory {
  CONTRACT
  INVOICE
  PROPOSAL
  BRIEFING
  SCREENSHOT
  DIAGRAM
  LEGAL
  AVV
  DPA
  OTHER
}

enum ServerStatus {
  ONLINE
  DEGRADED
  OFFLINE
  MAINTENANCE
  DECOMMISSIONED
}

enum DeploymentStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum DeploymentEnv {
  DEV
  STAGING
  PRODUCTION
}

// ═══════════════════════════════════════════════════════════════════════════
// WORKSPACE & AUTH
// ═══════════════════════════════════════════════════════════════════════════

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  clients     Client[]
  leads       Lead[]
  projects    Project[]
  decisions   Decision[]
  invoices    Invoice[]
  payments    Payment[]
  expenses    Expense[]
  estimates   PipelineEstimate[]
  activities  Activity[]
  credentials Credential[]
  documents   Document[]
  servers     Server[]
  deployments Deployment[]
  entries     KnowledgeEntry[]
}

model User {
  id           String    @id @default(cuid())
  workspaceId  String
  email        String
  passwordHash String
  name         String
  avatarUrl    String?
  role         Role
  clientId     String?
  ownerTag     OwnerTag?
  lastLoginAt  DateTime?
  timezone     String    @default("Europe/Berlin")
  locale       String    @default("de-DE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  client          Client?          @relation(fields: [clientId], references: [id])
  refreshTokens   RefreshToken[]
  impulses        Impulse[]        @relation("impulseAuthor")
  impulseResolved Impulse[]        @relation("impulseResolver")
  impulseComments ImpulseComment[]
  credentials     Credential[]     @relation("credentialCreator")
  documents       Document[]       @relation("documentUploader")
  journals        Journal[]        @relation("journalAuthor")
  entries         KnowledgeEntry[] @relation("entryAuthor")
  taskAssignees   TaskAssignee[]
  activities      Activity[]       @relation("activityActor")
  decisions       Decision[]       @relation("decisionAuthor")

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([clientId])
  @@index([deletedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
// CRM: LEADS & CLIENTS
// ═══════════════════════════════════════════════════════════════════════════

model Lead {
  id                String     @id @default(cuid())
  workspaceId       String
  companyName       String
  website           String?
  industry          String?
  location          String?
  employeeCount     String?
  pageSpeedScore    Int?
  scoreNote         String?    @db.Text
  scoreFetchedAt    DateTime?
  status            LeadStatus @default(NEW)
  tier              LeadTier?
  source            LeadSource
  sourceNote        String?
  primaryContactId  String?    @unique
  firstOutreachAt   DateTime?
  lastOutreachAt    DateTime?
  replyReceivedAt   DateTime?
  followUpCount     Int        @default(0)
  convertedAt       DateTime?
  convertedClientId String?    @unique
  rejectedReason    String?    @db.Text
  notes             String?    @db.Text
  tags              String[]
  // Inbound-specific fields (set when source = INBOUND)
  telefon           String?
  budget            String?
  zeitrahmen        String?
  problem           String?    @db.Text
  servicebedarf     String?    @db.Text
  branche           String?
  projekttypen      String[]
  ipAddress         String?
  userAgent         String?
  rawPayload        Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  primaryContact  ContactPerson?  @relation("leadPrimaryContact", fields: [primaryContactId], references: [id])
  convertedClient Client?         @relation(fields: [convertedClientId], references: [id])
  contacts        ContactPerson[] @relation("leadContacts")
  activities      Activity[]
  estimates       PipelineEstimate[]

  @@index([workspaceId])
  @@index([status])
  @@index([tier])
  @@index([deletedAt])
  @@index([workspaceId, status, deletedAt])
}

model Client {
  id                  String      @id @default(cuid())
  workspaceId         String
  name                String
  slug                String
  partnershipScope    String?     @db.Text
  stage               ClientStage @default(WARM)
  industry            String?
  website             String?
  monthlyRevenueCents Int?
  contractType        String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  workspace     Workspace        @relation(fields: [workspaceId], references: [id])
  users         User[]
  projects      Project[]
  contacts      ContactPerson[]
  credentials   Credential[]
  documents     Document[]
  servers       Server[]
  tasks         Task[]
  activities    Activity[]
  convertedFrom Lead?
  invoices      Invoice[]
  payments      Payment[]
  expenses      Expense[]
  estimates     PipelineEstimate[]
  entries       KnowledgeEntry[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([stage])
  @@index([deletedAt])
}

model ContactPerson {
  id        String   @id @default(cuid())
  clientId  String?
  leadId    String?
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  client        Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead          Lead?      @relation("leadContacts", fields: [leadId], references: [id], onDelete: Cascade)
  primaryForLead Lead?     @relation("leadPrimaryContact")
  activities    Activity[]

  @@index([clientId])
  @@index([leadId])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// PROJECTS
// ═══════════════════════════════════════════════════════════════════════════

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  clientId    String?
  name        String
  slug        String
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  type        ProjectType   @default(CLIENT_PROJECT)
  health      ProjectHealth @default(GREEN)
  startDate   DateTime?
  endDate     DateTime?
  budgetCents Int?
  spentCents  Int?
  repoUrl     String?
  prodUrl     String?
  stagingUrl  String?
  stack       String[]
  phase       String?
  areas       String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  client      Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  milestones  Milestone[]
  tasks       Task[]
  impulses    Impulse[]
  journals    Journal[]
  entries     KnowledgeEntry[]
  decisions   Decision[]
  credentials Credential[]
  documents   Document[]
  servers     Server[]
  deployments Deployment[]
  activities  Activity[]
  invoices    Invoice[]
  expenses    Expense[]
  estimates   PipelineEstimate[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([deletedAt])
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?         @db.Text
  status      MilestoneStatus @default(PLANNED)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
}

model Deployment {
  id          String           @id @default(cuid())
  workspaceId String
  projectId   String
  env         DeploymentEnv
  status      DeploymentStatus @default(PENDING)
  commitSha   String?
  commitMsg   String?          @db.Text
  branch      String?
  triggeredBy String?
  startedAt   DateTime         @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  coolifyRef  String?
  logUrl      String?
  errorMsg    String?          @db.Text

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@index([env])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════
// TASKS
// ═══════════════════════════════════════════════════════════════════════════

model Task {
  id            String       @id @default(cuid())
  kind          TaskKind     @default(TODO)
  title         String
  description   String?      @db.Text
  projectId     String
  clientId      String?
  milestoneId   String?
  ownerTag      OwnerTag?
  priority      TaskPriority @default(NORMAL)
  status        TaskStatus   @default(OPEN)
  dueDate       DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  blockedReason String?      @db.Text
  tags          String[]
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  milestone Milestone?     @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignees TaskAssignee[]
  blockedBy Task[]         @relation("TaskBlocks")
  blocks    Task[]         @relation("TaskBlocks")
  impulses  Impulse[]      @relation("impulseTask")
  activities Activity[]

  @@index([projectId])
  @@index([clientId])
  @@index([milestoneId])
  @@index([status])
  @@index([priority])
  @@index([completedAt])
  @@index([deletedAt])
  @@index([projectId, status, deletedAt])
  @@index([clientId, status, deletedAt])
}

model TaskAssignee {
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
// IMPULSES
// ═══════════════════════════════════════════════════════════════════════════

model Impulse {
  id              String          @id @default(cuid())
  projectId       String
  area            String?
  authorId        String
  type            ImpulseType
  title           String
  content         String          @db.Text
  status          ImpulseStatus   @default(NEW)
  priority        ImpulsePriority @default(NORMAL)
  resultingTaskId String?
  resolution      String?         @db.Text
  resolvedAt      DateTime?
  resolvedById    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author        User             @relation("impulseAuthor", fields: [authorId], references: [id])
  resolver      User?            @relation("impulseResolver", fields: [resolvedById], references: [id])
  resultingTask Task?            @relation("impulseTask", fields: [resultingTaskId], references: [id], onDelete: SetNull)
  comments      ImpulseComment[]
  activities    Activity[]
  documents     Document[]

  @@index([projectId])
  @@index([authorId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
}

model ImpulseComment {
  id        String    @id @default(cuid())
  impulseId String
  authorId  String
  content   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  impulse Impulse @relation(fields: [impulseId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([impulseId])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// KNOWLEDGE: JOURNAL, ENTRIES, DECISIONS
// ═══════════════════════════════════════════════════════════════════════════

model Journal {
  id             String      @id @default(cuid())
  kind           JournalKind
  title          String
  projectId      String
  authorId       String?
  occurredAt     DateTime
  content        String      @db.Text
  workDone       String?     @db.Text
  openItems      String?     @db.Text
  landmines      String?     @db.Text
  nextAction     String?     @db.Text
  relatedCommits String[]
  tags           String[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?   @relation("journalAuthor", fields: [authorId], references: [id])

  @@index([projectId])
  @@index([authorId])
  @@index([kind])
  @@index([occurredAt])
  @@index([deletedAt])
}

model KnowledgeEntry {
  id           String        @id @default(cuid())
  workspaceId  String
  title        String
  content      String        @db.Text
  category     EntryCategory
  projectId    String?
  clientId     String?
  authorId     String?
  meetingAt    DateTime?
  participants String?
  tags         String[]
  pinned       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author    User?     @relation("entryAuthor", fields: [authorId], references: [id])

  @@index([workspaceId])
  @@index([projectId])
  @@index([clientId])
  @@index([authorId])
  @@index([category])
  @@index([deletedAt])
  @@index([workspaceId, pinned, deletedAt])
  @@index([workspaceId, category, deletedAt])
}

model Decision {
  id              String         @id @default(cuid())
  workspaceId     String
  projectId       String?
  title           String
  context         String         @db.Text
  decision        String         @db.Text
  alternatives    String?        @db.Text
  consequences    String?        @db.Text
  authorId        String?
  status          DecisionStatus @default(ACTIVE)
  supersededById  String?        @unique
  decidedAt       DateTime
  tags            String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  workspace    Workspace  @relation(fields: [workspaceId], references: [id])
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  author       User?      @relation("decisionAuthor", fields: [authorId], references: [id])
  supersededBy Decision?  @relation("DecisionSuperseded", fields: [supersededById], references: [id])
  supersedes   Decision?  @relation("DecisionSuperseded")
  activities   Activity[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([status])
  @@index([decidedAt])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// ACTIVITY (unified touchpoint + audit log)
// ═══════════════════════════════════════════════════════════════════════════

model Activity {
  id              String           @id @default(cuid())
  workspaceId     String
  actorId         String?
  actorName       String?
  kind            ActivityKind
  channel         ActivityChannel?
  direction       Direction?
  clientId        String?
  projectId       String?
  contactId       String?
  leadId          String?
  impulseId       String?
  taskId          String?
  decisionId      String?
  subject         String?
  summary         String?          @db.Text
  changes         Json?
  occurredAt      DateTime         @default(now())
  durationMinutes Int?
  followUpAt      DateTime?
  followUpNote    String?
  tags            String[]
  createdAt       DateTime         @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id])
  actor     User?          @relation("activityActor", fields: [actorId], references: [id])
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contact   ContactPerson? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead      Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  impulse   Impulse?       @relation(fields: [impulseId], references: [id], onDelete: SetNull)
  task      Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  decision  Decision?      @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([actorId])
  @@index([kind])
  @@index([clientId])
  @@index([projectId])
  @@index([contactId])
  @@index([leadId])
  @@index([impulseId])
  @@index([taskId])
  @@index([decisionId])
  @@index([occurredAt])
  @@index([followUpAt])
  @@index([workspaceId, occurredAt(sort: Desc)])
  @@index([workspaceId, clientId, occurredAt(sort: Desc)])
  @@index([workspaceId, projectId, occurredAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════════
// FINANCIALS
// ═══════════════════════════════════════════════════════════════════════════

model Invoice {
  id             String        @id @default(cuid())
  workspaceId    String
  clientId       String
  projectId      String?
  invoiceNumber  String
  title          String
  issuedAt       DateTime
  dueAt          DateTime
  periodStart    DateTime?
  periodEnd      DateTime?
  subtotalCents  Int
  vatRateBps     Int           @default(1900)
  vatCents       Int
  totalCents     Int
  currency       String        @default("EUR")
  status         InvoiceStatus @default(DRAFT)
  kind           InvoiceKind   @default(ONE_OFF)
  pdfStoragePath String?
  sentAt         DateTime?
  sentToEmail    String?
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  client    Client            @relation(fields: [clientId], references: [id])
  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]
  payments  Payment[]
  documents Document[]
  estimate  PipelineEstimate?

  @@unique([workspaceId, invoiceNumber])
  @@index([workspaceId])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([issuedAt])
  @@index([deletedAt])
  @@index([workspaceId, status, deletedAt])
  @@index([workspaceId, issuedAt(sort: Desc)])
}

model InvoiceLineItem {
  id             String   @id @default(cuid())
  invoiceId      String
  description    String
  quantity       Decimal  @default(1) @db.Decimal(10, 2)
  unitPriceCents Int
  totalCents     Int
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id          String        @id @default(cuid())
  workspaceId String
  invoiceId   String?
  clientId    String?
  amountCents Int
  currency    String        @default("EUR")
  receivedAt  DateTime
  method      PaymentMethod
  reference   String?
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([invoiceId])
  @@index([clientId])
  @@index([receivedAt])
  @@index([deletedAt])
}

model Expense {
  id           String           @id @default(cuid())
  workspaceId  String
  name         String
  category     ExpenseCategory
  vendor       String?
  amountCents  Int
  currency     String           @default("EUR")
  frequency    ExpenseFrequency
  startedAt    DateTime?
  endedAt      DateTime?
  nextChargeAt DateTime?
  clientId     String?
  projectId    String?
  notes        String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([category])
  @@index([clientId])
  @@index([projectId])
  @@index([nextChargeAt])
  @@index([deletedAt])
}

model PipelineEstimate {
  id               String        @id @default(cuid())
  workspaceId      String
  leadId           String?
  clientId         String?
  projectId        String?
  title            String
  estimateMinCents Int
  estimateMaxCents Int
  probabilityPct   Int
  stage            PipelineStage @default(QUALIFIED)
  notes            String?       @db.Text
  closedAt         DateTime?
  closedReason     String?
  wonAsInvoiceId   String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  lead          Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  client        Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  wonAsInvoice  Invoice?  @relation(fields: [wonAsInvoiceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([clientId])
  @@index([stage])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// OPERATIONS: CREDENTIALS, DOCUMENTS, SERVERS
// ═══════════════════════════════════════════════════════════════════════════

model Credential {
  id            String         @id @default(cuid())
  workspaceId   String
  clientId      String?
  projectId     String?
  label         String
  type          CredentialType
  url           String?
  username      String?
  encValue      String         @db.Text
  encIv         String
  encTag        String
  notes         String?        @db.Text
  expiresAt     DateTime?
  lastRotatedAt DateTime?
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User      @relation("credentialCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([clientId])
  @@index([projectId])
  @@index([type])
  @@index([expiresAt])
  @@index([deletedAt])
}

model Document {
  id           String           @id @default(cuid())
  workspaceId  String
  clientId     String?
  projectId    String?
  invoiceId    String?
  impulseId    String?
  name         String
  displayName  String?
  mimeType     String
  sizeBytes    Int
  storagePath  String
  category     DocumentCategory
  tags         String[]
  uploadedById String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  impulse    Impulse?  @relation(fields: [impulseId], references: [id], onDelete: SetNull)
  uploadedBy User      @relation("documentUploader", fields: [uploadedById], references: [id])

  @@index([workspaceId])
  @@index([clientId])
  @@index([projectId])
  @@index([invoiceId])
  @@index([impulseId])
  @@index([category])
  @@index([deletedAt])
}

model Server {
  id               String       @id @default(cuid())
  workspaceId      String
  clientId         String?
  projectId        String?
  name             String
  provider         String?
  providerRef      String?
  url              String?
  ip               String?
  region           String?
  status           ServerStatus @default(ONLINE)
  statusNote       String?
  monthlyCostCents Int?
  lastChecked      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
}
