generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}

enum ClientStage {
  COLD
  WARM
  ACTIVE
  PRO_BONO
  PAUSED
  ENDED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum ProjectType {
  CLIENT_PROJECT
  PRODUCT
  INTERNAL
}

enum ProjectHealth {
  GREEN
  AMBER
  RED
}

enum ImpulseType {
  FEEDBACK
  CHANGE_REQUEST
  QUESTION
  IDEA
}

enum ImpulseStatus {
  NEW
  SEEN
  IN_PROGRESS
  DONE
}

enum CredentialType {
  LOGIN
  API_KEY
  ENV_VARIABLE
  SSH_KEY
  DATABASE
  OTHER
}

enum ServerStatus {
  ONLINE
  DEGRADED
  OFFLINE
  MAINTENANCE
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EntryCategory {
  CHANGELOG
  DECISION
  HANDOFF
  IDEA
  PLAN
  RESEARCH
  SPEC
  PLAYBOOK
  SOP
  MEETING_NOTE
  INSIGHT
  JOURNAL
  OTHER
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  clientId     String?
  createdAt    DateTime @default(now())

  client          Client?          @relation(fields: [clientId], references: [id])
  refreshTokens   RefreshToken[]
  impulses        Impulse[]
  impulseComments ImpulseComment[]
  credentials     Credential[]     @relation("credentialCreator")
  documents       Document[]       @relation("documentUploader")
  entries         KnowledgeEntry[] @relation("entryAuthor")
  assignedTasks   Task[]           @relation("taskAssignee")
  activities      ActivityLog[]    @relation("activityUser")

  @@index([clientId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Core Business ────────────────────────────────────────────────────────────

model Client {
  id                  String      @id @default(cuid())
  name                String
  slug                String      @unique
  partnershipScope    String?     @db.Text
  stage               ClientStage @default(WARM)
  industry            String?
  website             String?
  monthlyRevenueCents Int?
  contractType        String?
  createdAt           DateTime    @default(now())

  users       User[]
  projects    Project[]
  contacts    ContactPerson[]
  credentials Credential[]
  documents   Document[]
  entries     KnowledgeEntry[]
  servers     ServerEntry[]
  activities  ActivityLog[]
  tasks       Task[]
}

model Project {
  id          String        @id @default(cuid())
  clientId    String?
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  type        ProjectType   @default(CLIENT_PROJECT)
  health      ProjectHealth @default(GREEN)
  startDate   DateTime?
  budgetCents Int?
  spentCents  Int?
  repoUrl     String?
  prodUrl     String?
  stagingUrl  String?
  stack       String[]
  phase       String?
  createdAt   DateTime      @default(now())

  client      Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  areas       ProjectArea[]
  milestones  Milestone[]
  impulses    Impulse[]
  credentials Credential[]
  documents   Document[]
  entries     KnowledgeEntry[]
  servers     ServerEntry[]
  tasks       Task[]

  @@index([clientId])
}

// ─── Project Sub-Models ───────────────────────────────────────────────────────

model ProjectArea {
  id        String @id @default(cuid())
  projectId String
  name      String
  sortOrder Int    @default(0)

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  impulses Impulse[]

  @@index([projectId])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── Impulse System ───────────────────────────────────────────────────────────

model Impulse {
  id            String        @id @default(cuid())
  projectId     String
  projectAreaId String?
  authorId      String
  type          ImpulseType
  title         String
  content       String        @db.Text
  status        ImpulseStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  area     ProjectArea?     @relation(fields: [projectAreaId], references: [id], onDelete: SetNull)
  author   User             @relation(fields: [authorId], references: [id])
  comments ImpulseComment[]

  @@index([projectId])
  @@index([authorId])
  @@index([status])
}

model ImpulseComment {
  id        String   @id @default(cuid())
  impulseId String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  impulse Impulse @relation(fields: [impulseId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([impulseId])
}

// ─── Task System ──────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  assigneeId  String?
  clientId    String?
  projectId   String?
  priority    TaskPriority @default(NORMAL)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignee User?    @relation("taskAssignee", fields: [assigneeId], references: [id])
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([assigneeId])
  @@index([clientId])
  @@index([projectId])
  @@index([completedAt])
}

// ─── Knowledge Base ───────────────────────────────────────────────────────────

model KnowledgeEntry {
  id        String        @id @default(cuid())
  title     String
  content   String        @db.Text
  category  EntryCategory
  clientId  String?
  projectId String?
  authorId  String?
  tags      String[]
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client  Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?    @relation("entryAuthor", fields: [authorId], references: [id])

  @@index([clientId])
  @@index([projectId])
  @@index([authorId])
  @@index([category])
}

// ─── CRM / Operations ────────────────────────────────────────────────────────

model Credential {
  id          String         @id @default(cuid())
  clientId    String?
  projectId   String?
  label       String
  type        CredentialType
  url         String?
  username    String?
  encValue    String         @db.Text
  encIv       String
  encTag      String
  notes       String?        @db.Text
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User     @relation("credentialCreator", fields: [createdById], references: [id])

  @@index([clientId])
  @@index([projectId])
}

model Document {
  id           String   @id @default(cuid())
  clientId     String?
  projectId    String?
  name         String
  displayName  String?
  mimeType     String
  sizeBytes    Int
  storagePath  String
  category     String?
  uploadedById String
  createdAt    DateTime @default(now())

  client     Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("documentUploader", fields: [uploadedById], references: [id])

  @@index([clientId])
  @@index([projectId])
  @@index([category])
}

model ContactPerson {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ServerEntry {
  id          String       @id @default(cuid())
  clientId    String?
  projectId   String?
  name        String
  provider    String?
  url         String?
  ip          String?
  status      ServerStatus @default(ONLINE)
  statusNote  String?
  lastChecked DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client  Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([projectId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  meta       String?  @db.Text
  clientId   String?
  createdAt  DateTime @default(now())

  user   User?   @relation("activityUser", fields: [userId], references: [id], onDelete: SetNull)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([clientId])
  @@index([createdAt])
}
